# ── Base de datos ─────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/nexbody
MONGO_DB=nexbody

# ── IA (plan engine) ──────────────────────────────────────────────────────────
# Obtener en: console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx

# ── Email transaccional (Resend) ──────────────────────────────────────────────
# Obtener en: resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM=NexBody <hola@nexbody.app>

# ── Pagos (Stripe) ────────────────────────────────────────────────────────────
# Obtener en: dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxx
# Obtener en: dashboard.stripe.com → Developers → Webhooks → endpoint secret
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx
# Crear en: dashboard.stripe.com → Products → Add product → Prices
STRIPE_PRICE_MONTHLY=price_xxxxxxxxxxxx
STRIPE_PRICE_ANNUAL=price_xxxxxxxxxxxx

# ── App URL (para redirects de Stripe) ───────────────────────────────────────
# En desarrollo: http://localhost:3000
# En producción: https://nexbody.app
APP_URL=http://localhost:3000

# ── Seguridad ─────────────────────────────────────────────────────────────────
# Mínimo 32 caracteres aleatorios — requerido en producción
# Generar: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=

# CORS — separar con comas (solo en producción)
# ALLOWED_ORIGINS=https://nexbody.app,https://panel.nexbody.app

# ── Búsqueda web (opcional) ──────────────────────────────────────────────────
TAVILY_API_KEY=

# ── Logs ─────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Entorno ──────────────────────────────────────────────────────────────────
# "development" o "production" — activa validaciones extra en producción
ENV=development
